<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>mazi future biko</title>

<!-- Google Font -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background: linear-gradient(135deg,#ff9a9e,#fad0c4,#fad0c4);
    overflow-x:hidden;
    color:white;
}

/* HERO SECTION */
.hero{
    min-height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
    position:relative;
}

.hero h1{
    font-size:4rem;
    font-weight:700;
    text-shadow:0 4px 15px rgba(0,0,0,0.3);
}

.hero p{
    margin-top:15px;
    font-size:1.2rem;
    max-width:700px;
    line-height:1.7;
}

/* BUTTON */
.btn{
    margin-top:30px;
    padding:14px 30px;
    border:none;
    border-radius:50px;
    background:white;
    color:#ff4b6e;
    font-size:1rem;
    font-weight:600;
    cursor:pointer;
    transition:0.3s;
    box-shadow:0 5px 20px rgba(0,0,0,0.2);
}

.btn:hover{
    transform:scale(1.08);
}

/* PHOTO SECTION */
.gallery{
    padding:60px 20px;
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
    max-width:1200px;
    margin:auto;
}

.card{
    background:rgba(255,255,255,0.15);
    backdrop-filter:blur(10px);
    border-radius:25px;
    overflow:hidden;
    transition:0.4s;
    box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

.card:hover{
    transform:translateY(-10px) scale(1.03);
}

.card img{
    width:100%;
    height:300px;
    object-fit:cover;
}

.card-content{
    padding:20px;
}

.card-content h3{
    margin-bottom:10px;
}

.card-content p{
    font-size:0.95rem;
    line-height:1.5;
}

/* HEARTS */
.heart{
    position:absolute;
    color:white;
    animation:float 6s linear infinite;
    opacity:0.7;
}

@keyframes float{
    0%{
        transform:translateY(100vh) scale(0);
    }
    100%{
        transform:translateY(-10vh) scale(1.5);
    }
}

/* CONFETTI */
.confetti{
    position:fixed;
    width:10px;
    height:10px;
    top:-10px;
    animation:fall linear forwards;
    z-index:999;
}

@keyframes fall{
    to{
        transform:translateY(110vh) rotate(720deg);
    }
}

/* FOOTER */
footer{
    text-align:center;
    padding:30px;
    font-size:1rem;
}

/* MOBILE */
@media(max-width:768px){
    .hero h1{
        font-size:2.5rem;
    }

    .hero p{
        font-size:1rem;
    }

    .card img{
        height:240px;
    }
}
</style>
</head>
<body>

<!-- Floating Hearts -->
<div id="hearts"></div>

<!-- HERO -->
<section class="hero">
    <h1>Forever & Always ❤️</h1>
    <p>
        Every love story is beautiful, but ours is my favorite.
        A small romantic photo website filled with memories, smiles, and love.
    </p>

    <button class="btn" onclick="startConfetti()">
        Celebrate Love 🎉
    </button>
</section>

<!-- GALLERY -->
<section class="gallery">

    <div class="card">
        <img src="https://images.unsplash.com/photo-1516589178581-6cd7833ae3b2?q=80&w=1200&auto=format&fit=crop" alt="">
        <div class="card-content">
            <h3>Beautiful Moments</h3>
            <p>Love is not about how many days, months, or years together. It’s about every moment.</p>
        </div>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1518199266791-5375a83190b7?q=80&w=1200&auto=format&fit=crop" alt="">
        <div class="card-content">
            <h3>Endless Smiles</h3>
            <p>Your smile is the reason my heart feels complete every single day.</p>
        </div>
    </div>

    <div class="card">
        <img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1?q=80&w=1200&auto=format&fit=crop" alt="">
        <div class="card-content">
            <h3>Forever Together</h3>
            <p>No matter where life takes us, my favorite place will always be beside you.</p>
        </div>
    </div>

</section>

<footer>
    Made with ❤️ for someone special
</footer>

<script>
/* FLOATING HEARTS */
function createHeart(){
    const heart = document.createElement("div");
    heart.classList.add("heart");
    heart.innerHTML = "❤";

    heart.style.left = Math.random() * window.innerWidth + "px";
    heart.style.fontSize = Math.random() * 20 + 15 + "px";
    heart.style.animationDuration = Math.random() * 3 + 3 + "s";

    document.body.appendChild(heart);

    setTimeout(()=>{
        heart.remove();
    },6000);
}

setInterval(createHeart,400);

/* CONFETTI */
function startConfetti(){

    const colors = [
        "#ff4b6e",
        "#ffffff",
        "#ffd700",
        "#ff69b4",
        "#ff1493"
    ];

    for(let i=0;i<180;i++){

        const confetti = document.createElement("div");
        confetti.classList.add("confetti");

        confetti.style.left = Math.random() * window.innerWidth + "px";
        confetti.style.background = colors[Math.floor(Math.random()*colors.length)];

        const size = Math.random() * 8 + 5;
        confetti.style.width = size + "px";
        confetti.style.height = size + "px";

        confetti.style.opacity = Math.random();

        confetti.style.animationDuration = Math.random() * 3 + 2 + "s";

        document.body.appendChild(confetti);

        setTimeout(()=>{
            confetti.remove();
        },5000);
    }
}
</script>

</body>
</html>
